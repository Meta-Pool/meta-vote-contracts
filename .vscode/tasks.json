{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"command": "cd near-workspaces-integration-test && cargo run && cd -",
			"problemMatcher": [
				"$rustc",
				"$rust-panic"
			],
			"group": "test",
			"label": "integration test"
		},
		{
			"type": "cargo",
			"command": "test",
			"problemMatcher": [
				"$rustc"
			],
			"group": "test",
			"label": "rust: cargo test"
		}
	]
}